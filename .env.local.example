# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── STRIPE ──────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_your_key
STRIPE_SECRET_KEY=sk_live_or_test_your_key
# Get this from: https://dashboard.stripe.com/webhooks → your endpoint → signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ─── STRIPE PRICE IDs ─────────────────────────────────────────────────────────
# Create these in Stripe Dashboard → Products → Add Product
# Pro Monthly: $9/month recurring
STRIPE_PRICE_PRO_MONTHLY=price_your_pro_monthly_id
# Pro Yearly: $84/year recurring ($7/month)
STRIPE_PRICE_PRO_YEARLY=price_your_pro_yearly_id
# Team Monthly: $29/month recurring
STRIPE_PRICE_TEAM_MONTHLY=price_your_team_monthly_id
# Team Yearly: $276/year recurring ($23/month)
STRIPE_PRICE_TEAM_YEARLY=price_your_team_yearly_id

# ─── APP ─────────────────────────────────────────────────────────────────────
# Your deployed URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ─── CONTACT FORM ────────────────────────────────────────────────────────────
# Get from formspree.io — sign up free, create a form, paste the ID here
FORMSPREE_ID=your_formspree_form_id
